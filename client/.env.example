# Leave unset to use relative /api/v1 (recommended: Vite proxy in dev, nginx in prod)
# VITE_API_URL=/api/v1

# Only set if the API is on a different origin than the SPA
# VITE_API_URL=http://localhost:5001/api/v1

# Optional Socket.IO origin (defaults to window.location.origin when using relative API)
# VITE_SOCKET_URL=http://localhost:5001
